# Conductor — environment variables
# Copy to .env and fill in real values. Never commit .env to version control.

# Required: LLM gateway base URL (replaces https://api.anthropic.com)
LLM_GATEWAY_URL=https://your-llm-gateway-url

# Required: LLM gateway API key
ANTHROPIC_API_KEY=sk-your-key-here

# Required: Search API token (used by LocalStubSecretStore when Vault is not running)
# When Vault IS running, this is only used to seed Vault via vault_setup.sh
CATALOG_API_TOKEN=your-catalog-api-token

# Required: Base URL of the search API (no trailing slash)
CATALOG_BASE_URL=https://your-instance.example.com

# Optional: Vault address (default: http://localhost:8200)
VAULT_ADDR=http://localhost:8200

# Optional: Vault token (default: dev-root-token for dev mode)
VAULT_TOKEN=dev-root-token

# Sprint 4 memory providers
MEMORY_PROVIDER=inmemory
REDIS_HOST=localhost
REDIS_PORT=6379
QDRANT_HOST=localhost
QDRANT_PORT=6333
MEM0_SERVER_URL=http://localhost:8888
MEM0_API_KEY=your-mem0-api-key
MEM0_POSTGRES_PASSWORD=mem0-dev
MEM0_JWT_SECRET=conductor-dev-jwt-secret

# Hashnode publishing (scripts/publish_hashnode.py)
# Get your token from: https://hashnode.com/settings/developer
HASHNODE_ACCESS_TOKEN=your-hashnode-access-token
# Find your publication ID in Hashnode dashboard → Blog settings → General
HASHNODE_PUBLICATION_ID=your-publication-id
