# Conductor sprint 4 — environment variables
# Copy to .env and fill in real values. Never commit .env to version control.

# Required: LLM gateway base URL (replaces https://api.anthropic.com)
LLM_GATEWAY_URL=https://your-llm-gateway-url-here

# Required: LLM gateway API key
ANTHROPIC_API_KEY=your-gateway-api-key-here

# Required: catalog API token (used by LocalStubSecretStore when Vault is not running)
CATALOG_API_TOKEN=your-catalog-api-token-here

# Required: catalog base URL (no trailing slash)
CATALOG_BASE_URL=https://your-tenant.example.com

# Sprint 4: memory provider selection (redis | qdrant | mem0 | inmemory)
# inmemory = no infra needed, used in CI and unit tests
MEMORY_PROVIDER=inmemory

# Sprint 4: Redis connection (used by RedisMemoryStore for K/V entity memory)
# Also used by SessionStore (Layer 1 session state) from Sprint 3
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Sprint 4: Qdrant connection (used by QdrantMemoryStore and Mem0MemoryStore)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Sprint 4: LLM used by Mem0 library + server for fact extraction
# claude-haiku-4-5 rejected by some gateway routes (temperature+top_p conflict)
MEM0_LLM_MODEL=gpt-4.1-mini

# Sprint 4: Mem0 server mode (only needed when MEMORY_PROVIDER=mem0-server)
# See conductor/repos/README.md for setup instructions
MEM0_SERVER_URL=http://localhost:8888
MEM0_API_KEY=your-mem0-api-key-here
MEM0_POSTGRES_PASSWORD=mem0-dev
MEM0_JWT_SECRET=conductor-dev-jwt-secret

# Optional: Vault address (default: http://localhost:8200)
VAULT_ADDR=http://localhost:8200

# Optional: Vault token (default: dev-root-token for dev mode)
VAULT_TOKEN=dev-root-token
